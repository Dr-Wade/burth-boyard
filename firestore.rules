rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isTeamLeader() {
      return isSignedIn() && userRole() == 'team-leader';
    }

    // Users collection: created on first login, readable by the user themselves and admins
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isAdmin();
    }

    // Teams: readable by any authenticated user, writable by team-leaders and admins
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isTeamLeader() || isAdmin();
      allow update: if isTeamLeader() || isAdmin();

      // Challenge subcollection: same rules as parent team
      match /challenges/{challengeId} {
        allow read: if isSignedIn();
        allow create: if isTeamLeader() || isAdmin();
        allow update: if isTeamLeader() || isAdmin();
      }
    }
  }
}
